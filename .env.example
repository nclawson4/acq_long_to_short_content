# Anthropic (Claude Haiku 4.5 for any LLM reasoning)
ANTHROPIC_API_KEY=

# Deepgram (transcription, nova-3)
DEEPGRAM_API_KEY=

# Vercel Blob (output MP4 storage)
BLOB_READ_WRITE_TOKEN=

# Upstash Redis (run state + cost ledger + cache)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Budget enforcement (USD)
PIPELINE_VIDEO_COST_TARGET=0.20
PIPELINE_VIDEO_COST_CEILING=1.00

# Per-stage hard limits
PIPELINE_MAX_TURNS=8
PIPELINE_MAX_WALL_SECONDS=720
PIPELINE_MAX_RETRIES_PER_STAGE=2

# Observability (optional — leave blank to disable OTLP export)
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
